# Leave this false while the contact form is not yet operational.
# Change it to true only after Gmail, Turnstile, and the private PHP configuration are ready.
VITE_CONTACT_FORM_ENABLED=false

# This site key is public and is compiled into the browser bundle when the form is enabled.
# Replace it with the production widget site key before enabling the form for Hostinger.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
